# =========================================================================
#  assembly8-review-finder  —  환경변수 예시
#  실제 키는 절대 커밋하지 않습니다. 이 파일을 복사해 `.env` 로 채우세요.
#    PowerShell:  Copy-Item .env.example .env
#    bash:        cp .env.example .env
# =========================================================================

# --- 네이버 검색 API (1차 소스, 필수) -------------------------------------
#  https://developers.naver.com/ 에서 애플리케이션 등록 후 발급
#  (비로그인 검색 API: 블로그/카페글/웹문서/뉴스)
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# --- 보조 소스 (2차, 선택 / v1 기본 비활성) -------------------------------
#  옵션 b) 서드파티 SERP API (serper.dev) — 키가 있으면 자동 활성화
SERPER_API_KEY=
#  옵션 a) 레거시 Google Custom Search (2027-01-01 종료, 신규 발급 불가)
#          기존 키가 있을 때만 사용
GOOGLE_CSE_KEY=
GOOGLE_CSE_CX=

# --- 쿼터 / 캐시 가드 ------------------------------------------------------
#  캐시 TTL(초). 기본 24시간 — 같은 검색은 하루 동안 외부 호출 없이 재사용
SEARCH_CACHE_TTL=86400
#  네이버 일일 호출 한도 가드. 개발자센터에서 현재 한도 확인 후 보수적으로 설정
NAVER_DAILY_QUOTA_GUARD=24000

# --- 동작 옵션 -------------------------------------------------------------
#  쿼리 1건당 만들 변형(variant) 최대 개수. 클수록 폭↑ 쿼터 소모↑
MAX_QUERY_VARIANTS=4
#  변형 1건당 네이버 카테고리에서 받아올 결과 수(최대 100)
NAVER_DISPLAY=20
#  데모 모드: 키가 없어도 샘플 데이터로 UI/엔드포인트를 시연 (1=on, 0=off)
DEMO_MODE=0

# --- 공개 카페 허용목록 --------------------------------------------------
#  네이버 카페 글 다수가 회원 전용이라 기본은 모두 제외(공개 URL만 노출).
#  가입 없이 열람 가능한 카페만 여기에 등록하면 그 카페 글은 노출된다.
#  값 = 카페 식별자(slug), 즉 cafe.naver.com/<slug> 의 <slug>. 쉼표로 여러 개.
#  예: PUBLIC_CAFE_ALLOWLIST=9waytutor,somecafe
PUBLIC_CAFE_ALLOWLIST=

# --- CORS (프론트 dev 서버 + 앱 오리진) -----------------------------------
#  쉼표로 구분. Vite(5173)와 Capacitor/Electron 앱 오리진이 기본 포함됩니다.
#  (모바일 앱에서 원격 백엔드를 쓰면 그 도메인을 추가하세요.)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,capacitor://localhost,https://localhost,http://localhost
